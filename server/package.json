    "make:immutable": "ts-node scripts/make-immutable.ts",
    "update:metadata": "ts-node scripts/update-metadata.ts",
    "list:tokens": "ts-node scripts/list-wallet-tokens.ts",
    "burn:lp": "ts-node scripts/burn-lp.ts"
  },
