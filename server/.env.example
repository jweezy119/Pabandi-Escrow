# Environment
PORT=5000
NODE_ENV=development
API_VERSION=v1
# Local dev: http://localhost:3000 | Production (Firebase): https://pabandi-42c5b.web.app/app
FRONTEND_URL=http://localhost:3000
# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/karachi_booking

# JWT Authentication
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars-long
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production-min-32-chars-long
JWT_REFRESH_EXPIRES_IN=30d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# SMS Notifications (Twilio) - Optional
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# OpenWA Gateway - Optional but preferred for WhatsApp delivery
OPENWA_API_URL=http://localhost:2785/api
OPENWA_API_KEY=
OPENWA_SESSION_ID=

# Meta WhatsApp Cloud API - Optional fallback
META_WA_ACCESS_TOKEN=
META_WA_PHONE_NUMBER_ID=

# Email Notifications - Optional
EMAIL_SERVICE=smtp
EMAIL_FROM=noreply@pabandi.com

# SMTP Configuration (if EMAIL_SERVICE=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# SendGrid (if EMAIL_SERVICE=sendgrid)
SENDGRID_API_KEY=

# Payment Gateway - Optional
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
EASYPAISA_MERCHANT_ID=
EASYPAISA_PASSWORD=
