generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String           @id @default(cuid())
  email             String           @unique
  phone             String?          @unique
  passwordHash      String
  firstName         String
  lastName          String
  role              UserRole         @default(CUSTOMER)
  isEmailVerified   Boolean          @default(false)
  isPhoneVerified   Boolean          @default(false)
  reliabilityScore  Float            @default(750)
  fcmToken          String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  googleId          String?          @unique
  facebookId        String?          @unique
  resetToken        String?
  resetTokenExpires DateTime?
  linkedinId        String?          @unique
  profilePictureUrl String?
  tiktokId          String?          @unique
  twitterId         String?          @unique
  referredById      String?
  business          Business?
  cryptoRewards     CryptoReward[]
  payments          Payment[]
  reservations      Reservation[]
  socialIdentities  SocialIdentity[]
  referredBy        User?            @relation("UserReferrals", fields: [referredById], references: [id])
  referrals         User[]           @relation("UserReferrals")
  wallet            Wallet?
  stakeTransactions StakeTransaction[]
  stakingPositions  StakingPosition[]
  disputesAgainst   Dispute[]        @relation("DisputesAgainst")
  disputesFiled     Dispute[]        @relation("DisputesFiled")
  flags             UserFlag[]

  @@index([email])
  @@index([phone])
}

model Business {
  id                 String            @id @default(cuid())
  ownerId            String?           @unique
  name               String
  description        String?
  category           BusinessCategory
  address            String
  city               String            @default("")
  country            String            @default("United States")
  postalCode         String?
  phone              String
  email              String
  website            String?
  logoUrl            String?
  coverImageUrl      String?
  latitude           Float?
  longitude          Float?
  timezone           String            @default("America/New_York")
  currency           String            @default("USD")
  bookingAdvanceDays Int               @default(30)
  cancellationHours  Int               @default(24)
  requireDeposit     Boolean           @default(false)
  depositAmount      Float?
  depositPercentage  Float?
  isVerified         Boolean           @default(false)
  isActive           Boolean           @default(true)
  isPremium          Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  googlePlaceId      String?
  rating             Float?
  reviewCount        Int               @default(0)
  reliabilityScore   Float?
  state              String            @default("")
  isClaimed          Boolean           @default(true)
  externalBookingUrl String?
  slug               String?           @unique
  owner              User?             @relation(fields: [ownerId], references: [id])
  businessHours      BusinessHours[]
  settings           BusinessSettings?
  googleReviews      GoogleReview[]
  reservations       Reservation[]
  sourcingOrders     SourcingOrder[]
  tables             Table[]
  trendSuggestions   TrendSuggestion[]
  webhookEndpoints   WebhookEndpoint[]

  @@index([ownerId])
  @@index([city])
  @@index([category])
}

model BusinessHours {
  id         String   @id @default(cuid())
  businessId String
  dayOfWeek  Int
  openTime   String
  closeTime  String
  isClosed   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, dayOfWeek])
  @@index([businessId])
}

model Table {
  id           String        @id @default(cuid())
  businessId   String
  name         String
  capacity     Int
  isActive     Boolean       @default(true)
  metadata     Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  reservations Reservation[]
  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model Reservation {
  id                  String            @id @default(cuid())
  businessId          String
  customerId          String
  tableId             String?
  reservationDate     DateTime
  reservationTime     String
  numberOfGuests      Int
  status              ReservationStatus @default(PENDING)
  customerName        String
  customerPhone       String
  customerEmail       String?
  specialRequests     String?
  noShowProbability   Float?
  riskScore           Int?
  aiFactors           Json?
  reminderSentAt      DateTime?
  confirmationSentAt  DateTime?
  depositRequired     Boolean           @default(false)
  depositAmount       Float?
  depositPaid         Boolean           @default(false)
  source              String?
  notes               String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  cancelledAt         DateTime?
  cryptoDepositTxHash String?
  rewardEarned        Float?            @default(0)
  googleReviewId      String?
  depositStatus       DepositStatus     @default(NOT_REQUIRED)
  conciergeDetails    Json?
  isConcierge         Boolean           @default(false)
  cryptoRewards       CryptoReward[]
  payments            Payment[]
  business            Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer            User              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  table               Table?            @relation(fields: [tableId], references: [id])

  @@index([businessId])
  @@index([customerId])
  @@index([reservationDate])
  @@index([status])
  @@index([businessId, reservationDate])
}

model Payment {
  id              String        @id @default(cuid())
  reservationId   String?
  userId          String
  amount          Float
  currency        String        @default("USD")
  status          PaymentStatus @default(PENDING)
  paymentMethod   String
  transactionId   String?       @unique
  gatewayResponse Json?
  refunded        Boolean       @default(false)
  refundedAt      DateTime?
  refundAmount    Float?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  reservation     Reservation?  @relation(fields: [reservationId], references: [id])
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@index([userId])
  @@index([transactionId])
  @@index([status])
}

model BusinessSettings {
  id                    String   @id @default(cuid())
  businessId            String   @unique
  autoConfirm           Boolean  @default(true)
  requirePhone          Boolean  @default(true)
  requireEmail          Boolean  @default(false)
  allowSameDayBooking   Boolean  @default(true)
  maxAdvanceBookingDays Int      @default(30)
  minBookingNoticeHours Int      @default(2)
  aiEnabled             Boolean  @default(true)
  aiRiskThreshold       Int      @default(70)
  autoRequireDeposit    Boolean  @default(false)
  sendEmailReminders    Boolean  @default(true)
  reminderHoursBefore   Int      @default(24)
  sendPushReminders           Boolean  @default(true)
  sendWhatsAppReminders       Boolean  @default(true)
  notifyOwnerOnNewBooking     Boolean  @default(true)
  whatsappNumber              String?
  requestFeedbackAfterBooking Boolean  @default(true)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  business              Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model NotificationLog {
  id            String    @id @default(cuid())
  reservationId String
  type          String
  recipient     String
  subject       String?
  message       String
  status        String
  errorMessage  String?
  sentAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([reservationId])
  @@index([status])
}

model Wallet {
  id                String    @id @default(cuid())
  userId            String    @unique
  address           String?
  balance           Float     @default(0)
  totalStaked       Float     @default(0)
  currency          String    @default("PAB")
  airdropClaimed    Boolean   @default(false)
  airdropAmount     Float?
  airdropClaimedAt  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}


model CryptoReward {
  id            String       @id @default(cuid())
  userId        String
  reservationId String?
  amount        Float
  type          String
  status        String       @default("CLAIMABLE")
  txHash        String?
  createdAt     DateTime     @default(now())
  metadata      Json?
  reservation   Reservation? @relation(fields: [reservationId], references: [id])
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GoogleReview {
  id             String   @id @default(cuid())
  businessId     String
  googleReviewId String   @unique
  authorName     String
  rating         Int
  text           String?
  time           DateTime
  sentimentLabel String?
  processed      Boolean  @default(false)
  createdAt      DateTime @default(now())
  business       Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model WebhookEndpoint {
  id               String   @id @default(cuid())
  businessId       String
  targetUrl        String
  subscribedEvents String[]
  isActive         Boolean  @default(true)
  signingSecret    String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  business         Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model ApiClient {
  id                String        @id @default(cuid())
  name              String
  email             String        @unique
  apiKey            String        @unique
  tier              ApiTier       @default(STARTER)
  callsUsed         Int           @default(0)
  callsLimit        Int           @default(500)
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  paymentMethod     String?
  transactionHash   String?       @unique
  walletAddress     String?
  billingMode       BillingMode   @default(PAY_AS_YOU_GO)
  preferredCurrency CurrencyType  @default(PAB)
  usageLogs         ApiUsageLog[]
  disputes          Dispute[]

  @@index([apiKey])
  @@index([email])
}

model ApiUsageLog {
  id         String    @id @default(cuid())
  clientId   String
  endpoint   String
  statusCode Int
  latencyMs  Int
  createdAt  DateTime  @default(now())
  costCrypto Float     @default(0)
  costFiat   Float     @default(0)
  client     ApiClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([createdAt])
}

model SocialIdentity {
  id             String         @id @default(cuid())
  userId         String
  platform       SocialPlatform
  platformHandle String?
  accountAgeDays Int?
  isVerified     Boolean        @default(false)
  completeness   Float?
  rating         Float?
  completionRate Float?
  accountLevel   String?
  trustBoost     Float          @default(0.0)
  connectedAt    DateTime       @default(now())
  lastRefreshed  DateTime       @default(now())
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@index([userId])
}

model SourcingOrder {
  id               String              @id @default(cuid())
  businessId       String
  items            Json
  status           SourcingOrderStatus @default(SUGGESTED)
  estimatedCostPKR Float
  accioWorkOrderId String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  business         Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model TrendSuggestion {
  id                    String      @id @default(cuid())
  businessId            String
  equipmentName         String
  description           String
  estimatedCostPKR      Float
  suggestedServicePrice Float
  projectedBookings     Int
  projectedRoiPercent   Float
  status                TrendStatus @default(SUGGESTED)
  accioWorkUrl          String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  business              Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

enum UserRole {
  BUSINESS_OWNER
  BUSINESS_STAFF
  CUSTOMER
  ADMIN
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
  PENDING_CONCIERGE
  FAILED_CONCIERGE
}

enum DepositStatus {
  NOT_REQUIRED
  PENDING
  PAID
  APPLIED_TO_SERVICE
  REIMBURSED_TO_BUSINESS
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  JAZZCASH
  EASYPAISA
  CASH
  CRYPTO
  STRIPE
}

enum BusinessCategory {
  RESTAURANT
  SALON
  SPA
  CLINIC
  FITNESS_CENTER
  EVENT_VENUE
  OTHER
  HOSPITAL
  FREELANCE
}

enum ApiTier {
  STARTER
  GROWTH
  ENTERPRISE
}

enum BillingMode {
  PAY_AS_YOU_GO
  MONTHLY_SUBSCRIPTION
}

enum CurrencyType {
  FIAT
  PAB
}

enum SocialPlatform {
  LINKEDIN
  X_TWITTER
  WHATSAPP
  TIKTOK
  INSTAGRAM
  FACEBOOK
  FIVERR
  UPWORK
}

enum SourcingOrderStatus {
  SUGGESTED
  ORDERED
  SHIPPED
  FULFILLED
  CANCELLED
}

enum TrendStatus {
  SUGGESTED
  SOURCED
  SERVICE_LAUNCHED
  DISMISSED
}

model StakeTransaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Float
  type      String   // 'STAKE' or 'UNSTAKE'
  apyAtTime Float?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model StakingPosition {
  id        String   @id @default(cuid())
  userId    String
  amount    Float    // Amount of PAB staked
  status    String   @default("ACTIVE") // 'ACTIVE', 'WITHDRAWN'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Dispute {
  id            String         @id @default(cuid())
  userId        String
  reportedById  String?
  apiClientId   String?
  type          DisputeType
  description   String?
  outcome       DisputeOutcome @default(PENDING)
  resolvedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation("DisputesAgainst", fields: [userId], references: [id], onDelete: Cascade)
  reporter      User?          @relation("DisputesFiled", fields: [reportedById], references: [id])
  apiClient     ApiClient?     @relation(fields: [apiClientId], references: [id])

  @@index([userId])
  @@index([apiClientId])
}

model UserFlag {
  id        String   @id @default(cuid())
  userId    String
  flag      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, flag])
  @@index([userId])
}

enum DisputeType {
  NO_SHOW
  FRAUD
  NON_PAYMENT
  HARASSMENT
  QUALITY_ISSUE
  OTHER
}

enum DisputeOutcome {
  PENDING
  UPHELD
  DISMISSED
  RESOLVED
}
